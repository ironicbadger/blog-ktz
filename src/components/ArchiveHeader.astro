---
import { assetUrl } from '../lib/site';

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
}

const { title, description, image } = Astro.props;
const background = assetUrl(image);
---

<header class:list={['archive-header', { 'archive-header--image': background }]} style={background ? `--archive-image: url("${background}")` : undefined}>
	<div class="archive-header-shade" aria-hidden="true"></div>
	<div class="inner archive-header-content">
		<h1>{title}</h1>
		{description && <p>{description}</p>}
	</div>
</header>
