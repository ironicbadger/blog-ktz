# The importer can discover the public Content API key from the live homepage.
GHOST_URL=https://blog.ktz.me
GHOST_CONTENT_KEY=

# Empty means serve the mirrored Ghost tree locally from /content/.
# Set this to the R2 custom domain for a production build, for example:
# PUBLIC_ASSET_BASE_URL=https://assets.ktz.me
PUBLIC_ASSET_BASE_URL=
